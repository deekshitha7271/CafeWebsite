# ─────────────────────────────────────────────────────────────────
# Caphe Bistro — Local Kitchen Bridge Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────

# URL of your deployed main backend (no trailing slash)
BACKEND_URL=https://your-deployed-backend.onrender.com

# Thermal printer type: epson | star | citizen
PRINTER_TYPE=epson

# Printer interface:
#   TCP/IP (network printer): tcp://192.168.1.100
#   USB (Windows):            \\\\.\COM1  (or the COM port for your USB receipt printer)
#   USB (Linux/Mac):          /dev/usb/lp0
PRINTER_INTERFACE=tcp://192.168.1.100

# Optional: Number of characters per line (most 80mm printers = 42)
PRINTER_WIDTH=42

# The allowed CORS origin to present to the backend.
# In dev: leave blank (defaults to http://localhost:5173)
# In production: set this to your deployed frontend URL (e.g. https://caphe-bistro.vercel.app)
CORS_ORIGIN=
